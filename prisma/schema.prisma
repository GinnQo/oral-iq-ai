generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TEACHER
  ADMIN
}

enum AssessmentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionPlan {
  FREE
  FREE_TRIAL
  STUDENT_LEARNER
  INDIVIDUAL_TEACHER
  TUTOR_SMALL_ACADEMY
  SCHOOL_STARTER
  SCHOOL_PROFESSIONAL
  SCHOOL_PREMIUM
  SCHOOL
  ENTERPRISE
  TEACHER_MONTHLY
  TEACHER_ANNUAL
  SCHOOL_MONTHLY
  SCHOOL_ANNUAL
}

enum CustomerType {
  FREE
  FREE_TRIAL
  STUDENT_LEARNER
  INDIVIDUAL_TEACHER
  TUTOR_SMALL_ACADEMY
  SCHOOL_STARTER
  SCHOOL_PROFESSIONAL
  SCHOOL_PREMIUM
  SCHOOL
  ENTERPRISE
}

enum BillingCadence {
  NONE
  MONTH
  YEAR
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
  EXPIRED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  image           String?
  googleAccountId String?  @unique
  schoolId        String?
  role            UserRole @default(TEACHER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assessments       Assessment[]
  classrooms        Classroom[]
  students          Student[]
  assessmentResults AssessmentResult[]
  createdSchools    School[]      @relation("SchoolCreatedBy")
  school            School?       @relation("SchoolMembers", fields: [schoolId], references: [id], onDelete: SetNull)
  subscription     Subscription? @relation("UserSubscription")

  @@index([schoolId])

  @@map("users")
}

model School {
  id               String   @id @default(cuid())
  name             String
  billingEmail     String?
  createdByUserId   String?
  stripeCustomerId  String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy   User?          @relation("SchoolCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members     User[]         @relation("SchoolMembers")
  subscription Subscription? @relation("SchoolSubscription")

  @@index([createdByUserId])
  @@index([stripeCustomerId])
  @@map("schools")
}

model Subscription {
  id                      String             @id @default(cuid())
  plan                    SubscriptionPlan
  status                  SubscriptionStatus
  customerType            CustomerType?
  billingCadence          BillingCadence?    
  stripeCustomerId        String?            @unique
  stripeSubscriptionId    String?            @unique
  stripeCheckoutSessionId  String?            @unique
  stripePriceId           String?
  stripeProductId         String?
  billingEmail            String?
  currency                String?            @default("usd")
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  trialEndsAt             DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  canceledAt              DateTime?
  endedAt                 DateTime?
  metadata                Json?
  userId                  String?            @unique
  schoolId                String?            @unique
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user   User?   @relation("UserSubscription", fields: [userId], references: [id], onDelete: SetNull)
  school School? @relation("SchoolSubscription", fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([plan])
  @@index([customerType])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model Assessment {
  id            String           @id @default(cuid())
  userId        String
  title         String
  activityType  String?
  grade         String?
  duration      String?
  skillFocus    String?
  rubric        String?
  presenterType String?
  status        AssessmentStatus @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  results AssessmentResult[]

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("assessments")
}

model Classroom {
  id             String    @id @default(cuid())
  userId         String
  googleCourseId String
  name           String
  section        String?
  room           String?
  description    String?
  courseState    String?
  active         Boolean   @default(true)
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  enrollments ClassroomStudent[]

  @@unique([userId, googleCourseId])
  @@index([userId])
  @@index([googleCourseId])
  @@index([active])
  @@map("classrooms")
}

model Student {
  id              String   @id @default(cuid())
  userId          String
  googleStudentId String
  name            String
  email           String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  enrollments ClassroomStudent[]

  @@unique([userId, googleStudentId])
  @@index([userId])
  @@index([googleStudentId])
  @@index([email])
  @@index([active])
  @@map("students")
}

model ClassroomStudent {
  id          String           @id @default(cuid())
  classroomId String
  studentId   String
  status      EnrollmentStatus @default(ACTIVE)
  importedAt  DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([classroomId])
  @@index([studentId])
  @@index([status])
  @@map("classroom_students")
}

model AssessmentResult {
  id                String   @id @default(cuid())
  userId            String
  assessmentId      String?
  presentationType  String
  title             String?
  grade             String?
  rubric            String?
  topic             String?
  transcript        String
  duration          Float
  aiScore           Float?
  teacherFinalScore Float?
  teacherReviewNote String?
  studentNames      Json
  segments          Json
  detectedSpeakers  Json
  speakerMappings   Json
  speakerStatistics Json
  overlapWarnings   Json
  warnings          Json
  groupAssessment   Json
  individualResults Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  assessment Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assessmentId])
  @@index([createdAt])
  @@index([teacherFinalScore])
  @@map("assessment_results")
}
